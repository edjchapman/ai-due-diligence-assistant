# All runtime env vars are validated by src/config.ts (zod); invalid values fail at boot.

# Postgres (pgvector) connection
DATABASE_URL=postgres://postgres@localhost:5432/ai_dd
PORT=3000

# API keys — only needed when the matching provider switch below is non-local.
# OpenAI — embeddings (text-embedding-3-small); used by `npm run ingest` and /search
OPENAI_API_KEY=
# Anthropic — the reasoning agent (M3), plus the judge/extractor when switched to anthropic
ANTHROPIC_API_KEY=

# Provider switches (defaults shown; every `local` path is keyless and deterministic —
# it's what `make demo`, `make eval`, and CI run).
#EMBED_PROVIDER=openai      # openai | local
#LLM_PROVIDER=anthropic     # anthropic | local
#EXTRACT_PROVIDER=local     # local | anthropic  (ingest-path: defaults keyless on purpose)
#JUDGE_PROVIDER=local       # local | anthropic  (LLM-as-judge for `make eval`)
#PDF_PROVIDER=local         # local (unpdf) | textract (documented swap, not built)

# Eval gate: minimum passing score 0–1 (default comes from src/golden.ts)
#EVAL_THRESHOLD=1
