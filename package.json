{
  "name": "ai-due-diligence-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI due-diligence assistant: cited-source reports via a LangGraph.js agent, a CI-runnable eval harness, and a typed React 19 + Vite demo UI. TypeScript/Node.js portfolio project.",
  "license": "MIT",
  "author": "Ed Chapman (https://github.com/edjchapman)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edjchapman/ai-due-diligence-assistant.git"
  },
  "homepage": "https://app-production-e60e.up.railway.app",
  "bugs": {
    "url": "https://github.com/edjchapman/ai-due-diligence-assistant/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "npm run db:migrate && npm run ingest && npm run start",
    "typecheck": "tsc && tsc -p web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "ingest": "tsx src/ingest.ts",
    "fixtures:pdf": "tsx scripts/generate-pdf-fixtures.ts",
    "demo": "tsx src/demo.ts",
    "eval": "tsx src/eval.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "build:web": "vite build",
    "dev:web": "vite",
    "pretest": "vite build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.14",
    "@ai-sdk/openai": "^4.0.13",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@langchain/langgraph": "^1.4.7",
    "ai": "^7.0.26",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "postgres": "^3.4.5",
    "tsx": "^4.23.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
