{
  "name": "ai-due-diligence-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI due-diligence assistant: cited-source reports over a company corpus via a LangGraph.js agent, with a CI-runnable eval harness. TypeScript/Node.js portfolio project.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "npm run db:migrate && npm run ingest && npm run start",
    "typecheck": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "ingest": "tsx src/ingest.ts",
    "fixtures:pdf": "tsx scripts/generate-pdf-fixtures.ts",
    "demo": "tsx src/demo.ts",
    "eval": "tsx src/eval.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.14",
    "@ai-sdk/openai": "^4.0.13",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@langchain/langgraph": "^1.4.7",
    "ai": "^7.0.26",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "postgres": "^3.4.5",
    "tsx": "^4.23.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
